# Server
NODE_ENV=production
PORT=4000
HOST=0.0.0.0

# CORS — comma-separated list of allowed frontend origins
# Example: https://yourdomain.com,https://www.yourdomain.com
ALLOWED_ORIGINS=https://gemstonediamond.com,https://www.gemstonediamond.com

# Protect admin/read endpoints (GET /api/* that returns stored submissions)
# Send via `Authorization: Bearer <token>` or `X-Admin-Token: <token>`
ADMIN_TOKEN=change_me_to_a_long_random_secret

# Upload limits
MAX_FILE_SIZE_MB=10
